# ── Python ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# ── Virtual environments ────────────────────────────────────
venv/
.venv/

# ── Data ────────────────────────────────────────────────────
# Never commit datasets or generated runs — only the folder
# structure (.gitkeep). Benchmark files go in framework/data/<task>/,
# archived synthetic runs in framework/data/generated/<task>/.
# (experiments/Denis/data/ has its own .gitignore with whitelisted plots.)
framework/data/**
!framework/data/**/
!framework/data/**/.gitkeep
# Explicit (redundant with framework/data/** above): never track dataset or
# run-artifact json/csv under framework/data, whatever the layout.
framework/data/**/*.json
framework/data/**/*.csv

# ── Run artifacts ───────────────────────────────────────────
# Results files are build artifacts, rewritten on every run —
# committing them keeps the working tree permanently dirty.
results.json
results/

# ── Secrets ─────────────────────────────────────────────────
# Keep example.env as the template; real keys go in .env (never committed).
.env

# ── Caches & tooling ────────────────────────────────────────
.pip-cache/
.devcontainer/

# ── IDE / OS noise ──────────────────────────────────────────
.idea/
.vscode/
.DS_Store

# ── Documentation & other noise ─────────────────────────────
docs
.superpowers